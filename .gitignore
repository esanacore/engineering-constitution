node_modules/

# scripts/lib/ holds libraries bootstrap.sh sources at runtime and MUST be
# tracked. Many developers carry a Python-flavored global gitignore (the one
# GitHub suggests for Python includes a bare `lib/` for build output), which
# silently excludes this directory from `git add -A`. A repository .gitignore
# outranks the global one, so this negation keeps the libraries committable on
# any machine. Without it, a clone gets a bootstrap.sh that sources files that
# do not exist.
!scripts/lib/
!scripts/lib/*.sh

# Secrets that should never be committed. See SECURITY.md's "Secrets Sweep"
# and scripts/check_secrets.sh, which checks this list is present.
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.ppk
id_rsa
id_dsa
id_ecdsa
id_ed25519
credentials.json
*serviceaccount*.json
*service-account*.json
.netrc
terraform.tfstate
terraform.tfstate.backup

# Raw dropped book sources (PDF/EPUB/DOCX/etc.) are never committed — only
# their generated summaries and the manifest are tracked. See
# KNOWLEDGE_SOURCES.md.
/sources/raw/*
!/sources/raw/.gitkeep
!/sources/raw/README.md

# Exception: a tiny worked demo fixture, tracked so the workflow is obvious
# out of the box. Safe to delete once you've dropped in a real source.
!/sources/raw/example/
!/sources/raw/example/sample-source.md
